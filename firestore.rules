rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------------------
    // HELPERS
    // -------------------------------------------------------------------------
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isUser(uid) { return isSignedIn() && request.auth.uid == uid; }
    
    // HARDCODED ADMIN CHECK (As per environment requirement)
    function isAdmin() { 
      return isVerified() || (isSignedIn() && request.auth.token.email == 'dnacultfitness@gmail.com'); 
    }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    // -------------------------------------------------------------------------
    // DEFAULT DENY
    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // Admins have full access to everything
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // USERS COLLECTION
    // -------------------------------------------------------------------------
    match /users/{userId} {
      // Users can get their own profile, and assigned trainers can get it too
      allow get: if isUser(userId) || (isSignedIn() && resource.data.assignedTrainerUid == request.auth.uid);
      
      // Trainers can list users assigned to them
      allow list: if isSignedIn() && (resource.data.assignedTrainerUid == request.auth.uid);
      
      // Users can create their own profile as 'client' by default
      // They cannot set themselves as admin.
      allow create: if isUser(userId) && 
                      request.resource.data.role in ['client', 'trainer'];
      
      // Users can update their own profile but cannot change their role if it's already set
      allow update: if isUser(userId) && 
                      (request.resource.data.role == resource.data.role || isAdmin());
      
      // Details subcollection
      match /details/{detailId} {
        allow read: if isUser(userId) || (isSignedIn() && get(/databases/$(database)/documents/users/$(userId)).data.assignedTrainerUid == request.auth.uid);
        allow write: if isUser(userId);
      }
    }

    // -------------------------------------------------------------------------
    // TRAINERS COLLECTION
    // -------------------------------------------------------------------------
    match /trainers/{trainerId} {
      // Any verified user can read trainers list to see who they can be assigned to
      allow read: if isVerified();
      // Only admins manage the trainers list
      allow write: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // MEMBERSHIPS COLLECTION
    // -------------------------------------------------------------------------
    match /memberships/{membershipId} {
      // Users can read their own membership status, and assigned trainers can read them
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        get(/databases/$(database)/documents/users/$(resource.data.userId)).data.assignedTrainerUid == request.auth.uid
      );
      // Users can create a membership application
      allow create: if isSignedIn() && (request.resource.data.userId == request.auth.uid);
      // Admins manage approvals and validity (handled by global admin rule, 
      // but users might need to update minor fields if allowed)
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid) && 
                      !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'expiryDate', 'approvedAiPlan']);
    }

    // -------------------------------------------------------------------------
    // AI PLANS COLLECTION
    // -------------------------------------------------------------------------
    match /aiPlans/{planId} {
      // Users own their AI plans, and their assigned trainers can read them
      allow read: if isSignedIn() && (
        isUser(resource.data.userId) || 
        get(/databases/$(database)/documents/users/$(resource.data.userId)).data.assignedTrainerUid == request.auth.uid
      );
      allow write: if isSignedIn() && isUser(request.resource.data.userId);
    }

    // -------------------------------------------------------------------------
    // PLAN APPROVAL REQUESTS
    // -------------------------------------------------------------------------
    match /planApprovalRequests/{requestId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (
        resource.data.trainerId == request.auth.uid || 
        resource.data.userId == request.auth.uid
      );
    }

    // -------------------------------------------------------------------------
    // APPOINTMENTS
    // -------------------------------------------------------------------------
    match /appointments/{appointmentId} {
      allow read: if isSignedIn() && (
        resource.data.trainerId == request.auth.uid || 
        resource.data.userId == request.auth.uid
      );
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        resource.data.trainerId == request.auth.uid
      );
    }

    // -------------------------------------------------------------------------
    // WEEKLY REPORTS COLLECTION
    // -------------------------------------------------------------------------
    match /weeklyReports/{reportId} {
      allow read: if isSignedIn() && (
        isUser(resource.data.userId) || 
        get(/databases/$(database)/documents/users/$(resource.data.userId)).data.assignedTrainerUid == request.auth.uid
      );
      allow create: if isSignedIn() && isUser(request.resource.data.userId);
    }

    // -------------------------------------------------------------------------
    // DAILY WORKOUTS COLLECTION
    // -------------------------------------------------------------------------
    match /dailyWorkouts/{workoutId} {
      // Users track their own workouts, trainers can read them
      allow read: if isSignedIn() && (
        isUser(resource.data.userId) || 
        get(/databases/$(database)/documents/users/$(resource.data.userId)).data.assignedTrainerUid == request.auth.uid
      );
      allow create: if isSignedIn() && isUser(request.resource.data.userId);
      // Users can only update their own if not approved yet
      allow update: if isSignedIn() && isUser(resource.data.userId) && 
                      resource.data.status == 'pending';
    }

    // -------------------------------------------------------------------------
    // NOTIFICATIONS COLLECTION
    // -------------------------------------------------------------------------
    match /notifications/{notifId} {
      allow read, update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid);
      // Admins or system can create notifications (global rule handles admin)
    }

    // -------------------------------------------------------------------------
    // SERVICES COLLECTION
    // -------------------------------------------------------------------------
    match /services/{serviceId} {
      allow read: if true; // Publicly readable
      allow write: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // MEMBERSHIP PLANS (Pricing) COLLECTION
    // -------------------------------------------------------------------------
    match /membershipPlans/{planId} {
      allow read: if true; // Publicly readable
      allow write: if isAdmin();
    }
  }
}
